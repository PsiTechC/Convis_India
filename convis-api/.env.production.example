# ============================================
# CONVIS API - Production Environment Template
# ============================================
# Copy this file to .env and fill in the values
# IMPORTANT: Never commit the actual .env file to git!

# ==================== ENVIRONMENT ====================
ENVIRONMENT=production

# ==================== DATABASE ====================
# MongoDB Connection (required)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/convis?retryWrites=true&w=majority
DATABASE_NAME=convis

# Redis (required for campaigns and Celery)
REDIS_URL=redis://localhost:6379

# ==================== SECURITY ====================
# JWT Secret for authentication (required - generate a strong random string)
JWT_SECRET=your-super-secure-jwt-secret-minimum-32-characters

# Encryption key for storing sensitive data (required - generate a strong random string)
ENCRYPTION_KEY=your-super-secure-encryption-key-minimum-32-characters

# ==================== URLS ====================
# Frontend URL (required)
FRONTEND_URL=https://webapp.convis.ai

# API Base URL (required - used for Twilio webhooks)
API_BASE_URL=https://api.convis.ai
BASE_URL=https://api.convis.ai

# CORS Origins (comma-separated, required)
CORS_ORIGINS=https://webapp.convis.ai,https://api.convis.ai

# ==================== AI / LLM APIs ====================
# OpenAI API Key (required for post-call AI processing)
OPENAI_API_KEY=sk-your-openai-api-key

# Anthropic API Key (optional - for Claude models)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# ==================== SPEECH / ASR ====================
# Deepgram API Key (required for real-time transcription)
DEEPGRAM_API_KEY=your-deepgram-api-key

# ==================== TEXT-TO-SPEECH ====================
# Choose one or more TTS providers

# Cartesia (recommended)
CARTESIA_API_KEY=sk_car_your-cartesia-key

# ElevenLabs (alternative)
ELEVENLABS_API_KEY=your-elevenlabs-key

# Sarvam (for Indian languages)
SARVAM_API_KEY=your-sarvam-key

# ==================== EMAIL ====================
# SendGrid (recommended for production)
SENDGRID_API_KEY=SG.your-sendgrid-key
SENDGRID_FROM_EMAIL=noreply@convis.ai

# SMTP (alternative)
# EMAIL_USER=your-email@gmail.com
# EMAIL_PASS=your-app-password
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USE_SSL=false

# ==================== TWILIO (TELEPHONY) ====================
# Required for making/receiving calls
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token

# ==================== CALENDAR INTEGRATIONS ====================
# Google Calendar OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://api.convis.ai/api/calendar/google/callback

# Microsoft Calendar/Outlook OAuth
MICROSOFT_CLIENT_ID=your-microsoft-client-id
MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret
MICROSOFT_TENANT_ID=common
MICROSOFT_REDIRECT_URI=https://api.convis.ai/api/calendar/microsoft/callback

# ==================== WORKFLOW AUTOMATION ====================
# n8n Integration
N8N_ENABLED=true
N8N_API_URL=https://your-n8n-instance.com
N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook
N8N_EDITOR_BASE_URL=https://your-n8n-instance.com
N8N_API_KEY=your-n8n-api-key

# ==================== CELERY ====================
# Celery for background tasks (use Redis)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ==================== CAMPAIGN SETTINGS ====================
DEFAULT_TIMEZONE=Asia/Kolkata
DEFAULT_MAX_ATTEMPTS=3
DEFAULT_RETRY_DELAYS=15,60,1440
CAMPAIGN_DISPATCH_INTERVAL_SECONDS=1

# ==================== FEATURE FLAGS ====================
ENABLE_CALENDAR_BOOKING=true
ENABLE_POST_CALL_AI=true
ENABLE_AUTO_RETRY=true

# ==================== LIVEKIT (voice media plane) ====================
# LiveKit Cloud project. Browser calls go to LIVEKIT_URL; phone calls enter
# through LiveKit SIP (Twilio Elastic SIP Trunking terminates at LIVEKIT_SIP_INBOUND_HOST).
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=APIxxxxxxxxxxxx
LIVEKIT_API_SECRET=secret-from-livekit-console
LIVEKIT_AGENT_NAME=convis-agent
# Outbound SIP trunk id created in LiveKit Cloud → Telephony. Its termination
# URI must point at your Twilio Elastic SIP Trunk's Termination URI.
LIVEKIT_SIP_OUTBOUND_TRUNK_ID=ST_xxxxxxxxxxxx
# The SIP hostname LiveKit exposes for inbound calls. The
# /api/inbound-calls/connect/{assistant_id} webhook returns TwiML that
# SIP-dials sip:<room>@${LIVEKIT_SIP_INBOUND_HOST}.
LIVEKIT_SIP_INBOUND_HOST=your-project-sip.livekit.cloud

# ==================== SERVER ====================
PORT=8000
HOST=0.0.0.0
