# Database Configuration
MONGODB_URI=mongodb://localhost:27017/
DATABASE_NAME=convis_db_name

# Email Configuration
EMAIL_USER=your-email@example.com
EMAIL_PASS=your-email-password

# Frontend URL (local dev)
FRONTEND_URL=http://localhost:3001
# Explicit CORS origins for local dev
CORS_ORIGINS=http://localhost:3001

# API Keys - ASR
DEEPGRAM_API_KEY=api key here 

# API Keys - TTS
SARVAM_API_KEY=api key here 
CARTESIA_API_KEY=api key here 
ELEVENLABS_API_KEY=api key here 

# Encryption Key (for storing user API keys)
ENCRYPTION_KEY=your-secret-encryption-key-change-this-in-production
